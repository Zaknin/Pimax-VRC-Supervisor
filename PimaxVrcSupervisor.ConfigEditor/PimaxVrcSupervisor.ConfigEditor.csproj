<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>PimaxVrcSupervisorConfigEditor</AssemblyName>
    <RootNamespace>PimaxVrcSupervisor.ConfigEditor</RootNamespace>
    <ApplicationIcon>Assets\config-editor.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\PimaxVrcSupervisor\supervisor.config.json" Link="supervisor.config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\README.md" Link="README.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
