{
  // Full path to Broken Eye. This app is started first.
  // If this path is missing or invalid, the supervisor opens a browse dialog and saves your selection here.
  "BrokenEyePath": "",

  // Start Broken Eye minimized, then try to minimize its main window after launch.
  "BrokenEyeStartMinimized": false,

  // Full path to VRCFaceTracking. This app starts after Broken Eye has had time to settle.
  // If this path is missing or invalid, the supervisor opens a browse dialog and saves your selection here.
  // The browse dialog starts in C:\Program Files (x86)\Steam\steamapps\common\VRCFaceTracking by default.
  "VrcFaceTrackingPath": "",

  // Start VRCFaceTracking minimized, then try to minimize its main window after launch.
  "VrcFaceTrackingStartMinimized": false,

  // Enable the OSCGoesBrrr workflow during headset sessions.
  // These apps are closed during normal VRChat/session cleanup, but they are not restarted when Pimax reconnects.
  "OscGoesBrrrEnabled": false,

  // When enabled, press L in the supervisor console to launch Intiface and then OscGoesBrrr.
  "OscGoesBrrrHotkeyEnabled": true,

  // Optional experimental BLE scanner. When enabled, the supervisor scans nearby BLE advertisements for Lovense names.
  // The L hotkey remains available as a fallback when OscGoesBrrrHotkeyEnabled is true.
  "OscGoesBrrrBleScannerEnabled": false,

  // Enable the in-process OSC router.
  // The router starts once before Broken Eye and VRCFaceTracking, forwards every OSC UDP packet unchanged,
  // and is not restarted during Pimax reconnects or app restart cycles.
  "OscRouterEnabled": false,

  // Local UDP port the OSC router listens on at 127.0.0.1.
  // If the endpoint is already in use, supervisor startup continues and Space can retry routing later.
  "OscRouterReceivePort": 9001,

  // OSC output routes. Each enabled route receives every packet VRChat sends to 127.0.0.1:OscRouterReceivePort.
  // Apps should still send OSC directly to VRChat at 127.0.0.1:9000.
  // If VRChat also discovers an app through OSCQuery, do not route to that same app receive port unless you want duplicate packets.
  "OscRoutes": [
    // {
    //   "Name": "Example app",
    //   "AppReceivePort": 9003,
    //   "Enabled": true
    // }
  ],

  // Full path to Intiface. The OSCGoesBrrr workflow starts this app first.
  "IntifacePath": "%APPDATA%\\IntifaceCentral\\intiface_central.exe",

  // Start Intiface minimized, then try to minimize its main window after launch.
  "IntifaceStartMinimized": false,

  // Full path to OscGoesBrrr. This app starts after Intiface is running.
  "OscGoesBrrrPath": "%LOCALAPPDATA%\\Programs\\OscGoesBrrr\\OscGoesBrrr.exe",

  // Start OscGoesBrrr minimized, then try to minimize its main window after launch.
  "OscGoesBrrrStartMinimized": false,

  // Process names used to check, attach to, and close Broken Eye. Do not include ".exe".
  "BrokenEyeProcessNames": [ "Broken Eye" ],

  // Process names used to check, attach to, and close VRCFaceTracking. Do not include ".exe".
  "VrcFaceTrackingProcessNames": [ "VRCFaceTracking" ],

  // Process names used to detect, attach to, and close Intiface. ".exe" is optional.
  "IntifaceProcessNames": [ "intiface_central.exe" ],

  // Process names used to detect, attach to, and close OscGoesBrrr. ".exe" is optional.
  "OscGoesBrrrProcessNames": [ "OscGoesBrrr.exe" ],

  // Optional apps to start after Broken Eye and VRCFaceTracking are running.
  // These apps are closed with the same managed-app cleanup used for Broken Eye and VRCFaceTracking.
  // The process name is inferred from Path.
  // Set RestartOnPimaxReconnect to false to leave an app running during the Pimax reconnect restart cycle.
  // Set RunAsAdmin to true only for extra apps that must run elevated.
  // Set StartMinimized to true to start an app minimized and then try to minimize its main window after launch.
  "AutoLaunchApps": [
    // {
    //   "Name": "Example overlay",
    //   "Path": "C:\\Tools\\ExampleOverlay\\ExampleOverlay.exe",
    //   "Enabled": true,
    //   "RestartOnPimaxReconnect": true,
    //   "RunAsAdmin": false,
    //   "StartMinimized": false
    // }
  ],

  // When any of these processes has been seen running and later closes, the supervisor closes both managed apps and exits.
  // If the watched app exits with a non-zero crash code, the supervisor waits for relaunch before exiting.
  "WatchedShutdownProcessNames": [ "VRChat" ],

  // SteamVR server process names. After VRChat exits, monitors are restored only after these processes are gone.
  "SteamVrServerProcessNames": [ "vrserver" ],

  // Enable SteamVR base station power automation.
  // Base stations are powered on only once after SteamVR server is running and the Pimax headset is connected.
  // They are not restarted when Pimax or other devices reconnect.
  // When OpenVR is available, startup checks SteamVR tracking 10 seconds after each wake cycle and retries up to 5 cycles until all enabled base stations are active.
  // If OpenVR is unavailable, wake pass 1 starts before managed apps; pass 2 runs after managed apps; V1/unsupported stations get pass 3 after 30 seconds.
  // After VRChat exits, the supervisor waits for SteamVR server to close before sending the selected power-down command.
  "BaseStationsEnabled": false,

  // Power-down command sent after VRChat and SteamVR have both closed.
  // Sleep works for Base Station 1.0 and 2.0. Standby is used only for Base Station 2.0; Base Station 1.0 falls back to sleep.
  "BaseStationPowerDownMode": "Sleep",

  // SteamVR base stations to manage.
  // Use the config editor's Base Stations tab to scan, rename, and test commands.
  // FriendlyName is only a user-facing alias; Name and BluetoothAddress keep the actual BLE identity visible.
  // Base Station 1.0 requires Id: the 8-character ID printed on the back label.
  // PowerStateReadUnsupported is set automatically when the station or firmware cannot report power state.
  // When true, the supervisor skips state reads for faster startup; use Config Editor Refresh State to retry manually.
  "BaseStations": [
    // {
    //   "FriendlyName": "Front left",
    //   "Name": "LHB-00000000",
    //   "BluetoothAddress": "AA:BB:CC:DD:EE:FF",
    //   "Version": "V2",
    //   "Enabled": true,
    //   "Id": "",
    //   "PowerStateReadUnsupported": false
    // }
  ],

  // Set to true if you use a Vive face/mouth tracker exposed as HTC Multimedia Camera.
  // Set to false to ignore all mouth-tracker detection and VRCFaceTracking-only restart logic.
  // Leave empty to show a Yes/No dialog on first run; the answer is saved here as true or false.
  "MouthTrackerUser": "",

  // Set to true to disable all secondary monitors while Broken Eye/VRCFaceTracking are running.
  // The full active monitor layout is saved first and restored after VRChat and SteamVR close.
  // Leave empty to show a Yes/No dialog on first run; the answer is saved here as true or false.
  "TurnOffSecondaryMonitors": "",

  // Leave empty to ask on first setup whether to create an elevated Windows Scheduled Task.
  // When enabled, the task starts this supervisor when VRChat.exe launches, but only if vrserver.exe is running.
  "AutoLaunchScheduledTask": "",

  // Pimax headset detection rules. Each inner array is one possible match rule.
  // A device counts as connected when any inner array has all of its keywords inside one connected-device block.
  // The USB\VID_34A4 rules are the actual Pimax HMD/runtime interfaces; EyeChip alone is not enough to count as a headset reconnect.
  "PimaxDetectors": [
    [ "USB\\VID_34A4&PID_0012" ],
    [ "USB\\VID_34A4&PID_0018" ],
    [ "USB\\VID_34A4&PID_0020" ],
    [ "USB\\VID_34A4&PID_0040" ],
    [ "USB\\VID_34A4&PID_0042" ],
    [ "USB\\VID_34A4&PID_0044" ],
    [ "USB\\VID_34A4&PID_0046" ],
    [ "Pimax", "Crystal" ],
    [ "Pimax", "P3C" ],
    [ "Pimax", "WiGig" ]
  ],

  // Vive mouth tracker detection rules. Each inner array is one possible match rule.
  // When this appears after being missing, only VRCFaceTracking is restarted.
  // Ignored when MouthTrackerUser is false.
  "MouthTrackerDetectors": [
    [ "USB\\VID_0BB4&PID_0321&MI_00" ],
    [ "HTC Multimedia Camera" ],
    [ "VIVE", "Camera" ]
  ],

  // Lovense detection rules. Each inner array is one possible match rule.
  // Direct Bluetooth/WebBluetooth Lovense toys usually advertise names starting with LVS-.
  // Add exact Windows hardware IDs or device names here if your adapter exposes them differently.
  "LovenseDetectors": [
    [ "Lovense" ],
    [ "LVS-" ]
  ],

  // Also watch Pimax PiService logs for fast HID remove/add reconnect bursts.
  // This catches short runtime drops that can happen between normal USB polling checks.
  "UsePimaxServiceLogReconnectDetector": true,

  // Also watch Windows Kernel-PnP events for fast Vive mouth tracker reconnects.
  // This catches short mouth tracker restarts that can happen between normal USB polling checks.
  "UseMouthTrackerPnPReconnectDetector": true,

  // Folder containing PiService__*.log files. Environment variables like %LOCALAPPDATA% are expanded.
  "PimaxServiceLogDirectory": "%LOCALAPPDATA%\\Pimax\\PiService\\Log",

  // Number of recent PiService log lines to scan each poll.
  "PimaxServiceLogReconnectLookbackLines": 400,

  // How often, in seconds, to check device and watched-process state.
  "PollIntervalSeconds": 2,

  // Maximum seconds to wait for an app to become visible as a running process.
  "StartupTimeoutSeconds": 30,

  // Seconds an app must remain running before startup verification succeeds.
  "StartupStableSeconds": 5,

  // Seconds to wait after starting Broken Eye before starting VRCFaceTracking.
  "DelayBeforeVrcFaceTrackingSeconds": 5,

  // Seconds to wait after Intiface is running before starting OscGoesBrrr.
  "DelayBeforeOscGoesBrrrSeconds": 5,

  // Seconds each BLE scan burst runs when OscGoesBrrrBleScannerEnabled is true.
  "OscGoesBrrrBleScanSeconds": 30,

  // Seconds to wait after each unsuccessful BLE scan before trying again.
  "OscGoesBrrrBleScanIntervalSeconds": 60,

  // Seconds to wait after the Pimax headset reconnects before restarting both managed apps.
  "RestartDelayAfterReconnectSeconds": 10,

  // If VRChat exits with a crash code, wait this many seconds for it to relaunch before closing apps and exiting.
  "WatchedProcessCrashRelaunchGraceSeconds": 300,

  // Seconds to wait for graceful app shutdown before force-closing the process tree.
  "ShutdownGraceSeconds": 8,

  // Maximum seconds to wait for the Windows device query command to return.
  "DeviceProbeTimeoutSeconds": 10
}
